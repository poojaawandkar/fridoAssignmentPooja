# Shopify Storefront API Configuration
# Copy this file to .env.local and fill in your values

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# Notes:
# 1. Get your Store Domain from your Shopify admin
# 2. Get your Storefront Access Token from Apps > App and Sales Channel Settings > Develop Apps
#    - You'll need to create a custom app with Storefront API access
#    - Required scopes: read_products
# 3. Store domains typically follow the pattern: your-store.myshopify.com